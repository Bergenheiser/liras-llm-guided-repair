LabSampleTransport

humans: Nurse, LabPersonnel
robots: Transporter, RoboticArm
locations: PatientFloor, Laboratory
resources: Sample

Transporter:
	1: moveTo PatientFloor
	2: receiveFrom Nurse
	3: moveTo Laboratory
	4: stop until !possess(Transporter, Sample)

RoboticArm:
	1-3: stop until position(Transporter, Laboratory)
	4: fetch Sample

LabPersonnel:
	1-3: stop until position(Transporter, Laboratory)
	4: fetch Sample

Nurse:
	1: stop until position(Transporter, PatientFloor)
	2: stop // The nurse hands over the sample, modeled by the Transporter's 'receiveFrom' action

success: possess(RoboticArm, Sample) || possess(LabPersonnel, Sample)
failure: time(600) // The process must complete within 600 time units as per protocol