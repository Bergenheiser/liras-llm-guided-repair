SampleDelivery

agents:
	humans: Nurse, LabPersonnel
	robots: TransportRobot, RoboticArm
locations: patientFloor, laboratory, lockedDrawer
resources: sample, barcode, analysisMachineEntryModule
NL
Nurse:
	1: collect(sample)
	2: insertDataTrackSystem(sample, barcode)
	3: requestDelivery(sample, laboratory)
	4:  stop
NL
TransportRobot:
	1: moveTo patientFloor
	2: receiveFrom Nurse
	   lockSample(lockedDrawer)
	3: moveTo laboratory
	   unlockSample(lockedDrawer)
NL
RoboticArm:
	1: moveTo laboratory
	2: pickUp(sample)
	   scan(barcode)
	3: sort(sample)
	4: load(analysisMachineEntryModule)
	5: log(location, time)
NL
LabPersonnel:
	1: moveTo laboratory
	2: unlockSample(lockedDrawer)
