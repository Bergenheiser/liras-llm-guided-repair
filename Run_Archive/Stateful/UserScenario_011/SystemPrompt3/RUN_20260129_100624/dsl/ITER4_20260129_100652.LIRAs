SampleTransportation

agents:
	humans: Nurse, LabPersonnel
	robots: TransportRobot, RoboticArm
locations: patientFloor1, patientFloor2, laboratory, reception
resources: sample, lockedDrawer

Nurse:
	1: collect(sample)
	2: insertSampleData(sample) in trackSystem
	3: requestDelivery(sample):
	
TransportRobot:
	1: moveTo Nurse
	2: collect(sample)
	3: moveTo laboratory
	4: deliver(sample):
	
RoboticArm:
	1: moveTo lab.entryModule
	2: open(lockedDrawer)
	3: pickup(sample)
	4: scanBarcode(sample)
	5: sort(sample)
	6: load(sample) in analysisMachine
	7: logData(sample)
	8: close(lockedDrawer)

LabPersonnel:
	1: pick(sample)
	2: moveTo entryModule
	3: open(lockedDrawer)
	4: pickup(sample)
	5: scanBarcode(sample)
	6: sort(sample)
	7: load(sample) in analysisMachine
	8: logData(sample)
	9: close(lockedDrawer)
