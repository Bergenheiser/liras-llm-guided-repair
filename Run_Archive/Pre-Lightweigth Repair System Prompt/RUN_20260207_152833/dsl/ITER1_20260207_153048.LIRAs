LabSamplesTransport

agents:
	humans: Nurse, LabPersonnel
	robots: TransportBot, RoboticArm
locations: PatientFloor, Laboratory
resources: Sample

Nurse:
	1: inputData
	2: moveTo PatientFloor
	3: deliver Sample

TransportBot:
	1-2: moveTo PatientFloor
	3: receiveFrom Nurse
	   lockDrawer
	4: moveTo Laboratory
	5: checkTime
	   unlockDrawer

RoboticArm:
	1-4: stop
	5: fetch Sample
	   scanBarcode
	   sort
	   loadEntryModule
	   logData