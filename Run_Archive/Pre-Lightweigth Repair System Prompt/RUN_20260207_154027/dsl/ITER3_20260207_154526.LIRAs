LabLogistics

agents:
	humans: Nurse, LabPersonnel
	robots: Transporter, Arm
locations: PatientFloor, Laboratory, AnalysisMachine
resources: Sample

Nurse:
	1: moveTo PatientFloor
	   leave Sample

Transporter:
	1: moveTo PatientFloor
	   restart if !possess(Nurse, Sample)
	2: fetch Sample
	3: moveTo Laboratory
	   until position(Arm, Laboratory)

Arm:
	1: restart if !possess(Transporter, Sample)
	   receiveFrom Transporter
	2: wait 2
	   moveTo AnalysisMachine
	3: deliver Sample

LabPersonnel:
	1: restart if !possess(Transporter, Sample)
	   receiveFrom Transporter
	2: wait 2
	   deliver Sample